<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.guitarix.GuitarixMac</string>
    <key>CFBundleName</key>
    <string>Guitarix</string>
    <key>CFBundleDisplayName</key>
    <string>Guitarix</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>NSHumanReadableCopyright</key>
    <string>© 2024 Guitarix Contributors. GPLv2.</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <!-- Audio input permission -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Guitarix needs microphone/audio input access to process your guitar signal.</string>
    <!-- Allow reading IR files from disk -->
    <key>NSDocumentsFolderUsageDescription</key>
    <string>Guitarix can load impulse response files from your Documents folder.</string>
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
